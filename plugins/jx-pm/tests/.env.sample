# Secrets only — org/project/GUID are hardcoded in helpers/sandbox.ts, not env vars.

# E2E tests: Work Items (Read & Write), Projects (Read) — scoped to Jodex-Test only
AZURE_DEVOPS_TOKEN=your_rw_pat_here

# Dry-run tests: Work Items (Read only), Projects (Read) — ensures write calls return 401
AZURE_DEVOPS_TOKEN_READONLY=your_readonly_pat_here

# Pre-run sweep: Work Items (Read, Write, Delete), Projects (Read) — hard-deletes stale Removed items in 901–999 range
AZURE_DEVOPS_TOKEN_CLEANUP=your_cleanup_pat_here

# Claude Agent SDK invocation (required for dry-run and E2E)
ANTHROPIC_API_KEY=your_api_key_here

# Optional: set to "true" to use hard-delete instead of PATCH-to-Removed for sandbox items
ADO_CLEANUP_DESTROY=
